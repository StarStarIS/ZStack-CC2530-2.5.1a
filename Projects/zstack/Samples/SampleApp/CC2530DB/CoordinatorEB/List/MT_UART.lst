    236          #if defined (ZAPP_P1) || defined (ZAPP_P2)
    237          /***************************************************************************************************
    238           * @fn      MT_UartProcessZAppData
    239           *
    240           * @brief   | SOP | CMD  |   Data Length   | FSC  |
    241           *          |  1  |  2   |       1         |  1   |
    242           *
    243           *          Parses the data and determine either is SPI or just simply serial data
    244           *          then send the data to correct place (MT or APP)
    245           *
    246           * @param   port    - UART port
    247           *          event   - Event that causes the callback
    248           *
    249           *
    250           * @return  None
    251           ***************************************************************************************************/
    252          void MT_UartProcessZAppData ( uint8 port, uint8 event )
    253          {
    254          
    255            osal_event_hdr_t  *msg_ptr;
    256            uint16 length = 0;
    257            uint16 rxBufLen  = Hal_UART_RxBufLen(MT_UART_DEFAULT_PORT);
    258          
    259            /*
    260               If maxZAppBufferLength is 0 or larger than current length
    261               the entire length of the current buffer is returned.
    262            */
    263            if ((MT_UartMaxZAppBufLen != 0) && (MT_UartMaxZAppBufLen <= rxBufLen))
    264            {
    265              length = MT_UartMaxZAppBufLen;
    266            }
    267            else
    268            {
    269              length = rxBufLen;
    270            }
    271          
    272            /* Verify events */
    273            if (event == HAL_UART_TX_FULL)
    274            {
    275              // Do something when TX if full
    276              return;
    277            }
    278          
    279            if (event & ( HAL_UART_RX_FULL | HAL_UART_RX_ABOUT_FULL | HAL_UART_RX_TIMEOUT))
    280            {
    281              if ( App_TaskID )
    282              {
    283                /*
    284                   If Application is ready to receive and there is something
    285                   in the Rx buffer then send it up
    286                */
    287                if ((MT_UartZAppRxStatus == MT_UART_ZAPP_RX_READY ) && (length != 0))
    288                {
    289                  /* Disable App flow control until it processes the current data */
    290                   MT_UartAppFlowControl (MT_UART_ZAPP_RX_NOT_READY);
    291          
    292                  /* 2 more bytes are added, 1 for CMD type, other for length */
    293                  msg_ptr = (osal_event_hdr_t *)osal_msg_allocate( length + sizeof(osal_event_hdr_t) );
    294                  if ( msg_ptr )
    295                  {
    296                    msg_ptr->event = SPI_INCOMING_ZAPP_DATA;
    297                    msg_ptr->status = length;
    298          
    299                    /* Read the data of Rx buffer */
    300                    HalUARTRead( MT_UART_DEFAULT_PORT, (uint8 *)(msg_ptr + 1), length );
    301          
    302                    /* Send the raw data to application...or where ever */
    303                    osal_msg_send( App_TaskID, (uint8 *)msg_ptr );
    304                  }
    305                }
    306              }
    307            }
    308          }
    309          
    310          /***************************************************************************************************
    311           * @fn      SPIMgr_ZAppBufferLengthRegister
    312           *
    313           * @brief
    314           *
    315           * @param   maxLen - Max Length that the application wants at a time
    316           *
    317           * @return  None
    318           *
    319           ***************************************************************************************************/
    320          void MT_UartZAppBufferLengthRegister ( uint16 maxLen )
    321          {
    322            /* If the maxLen is larger than the RX buff, something is not right */
    323            if (maxLen <= MT_UART_DEFAULT_MAX_RX_BUFF)
    324              MT_UartMaxZAppBufLen = maxLen;
    325            else
    326              MT_UartMaxZAppBufLen = 1; /* default is 1 byte */
    327          }
    328          
    329          /***************************************************************************************************
    330           * @fn      SPIMgr_AppFlowControl
    331           *
    332           * @brief
    333           *
    334           * @param   status - ready to send or not
    335           *
    336           * @return  None
    337           *
    338           ***************************************************************************************************/
    339          void MT_UartAppFlowControl ( bool status )
    340          {
    341          
    342            /* Make sure only update if needed */
    343            if (status != MT_UartZAppRxStatus )
    344            {
    345              MT_UartZAppRxStatus = status;
    346            }
    347          
    348            /* App is ready to read again, ProcessZAppData have to be triggered too */
    349            if (status == MT_UART_ZAPP_RX_READY)
    350            {
    351              MT_UartProcessZAppData (MT_UART_DEFAULT_PORT, HAL_UART_RX_TIMEOUT );
    352            }
    353          
    354          }
    355          
    356          #endif //ZAPP
