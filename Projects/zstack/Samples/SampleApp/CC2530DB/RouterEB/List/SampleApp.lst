    448          
    449          static void SampleApp_HandleLedCmd(uint8 ledNum, uint8 ledState)
    450          {
    451            uint8 ledMask = 0;
    452            uint8 rsp[7];
    453          
    454            switch (ledNum)
    455            {
    456              case 0x01:
    457                ledMask = HAL_LED_1;
    458                break;
    459          
    460              case 0x02:
    461                ledMask = HAL_LED_2;
    462                break;
    463          
    464              case 0x03:
    465                ledMask = HAL_LED_3;
    466                break;
    467          
    468              case 0x04:
    469                ledMask = HAL_LED_4;
    470                break;
    471          
    472              default:
    473                return;
    474            }
    475          
    476            if (ledState == 0x01)
    477            {
    478              HalLedSet(ledMask, HAL_LED_MODE_ON);
    479            }
    480            else if (ledState == 0x02)
    481            {
    482              HalLedSet(ledMask, HAL_LED_MODE_OFF);
    483            }
    484            else
    485            {
    486              return;
    487            }
    488          
    489            /* 响应协议与控制协议一致，原样回送 */
    490            rsp[0] = SH_START;
    491            rsp[1] = SH_TYPE_LED;
    492            rsp[2] = SAMPLEAPP_DEVICE_ADDR;
    493            rsp[3] = 0x02;
    494            rsp[4] = ledNum;
    495            rsp[5] = ledState;
    496            rsp[6] = SH_END;
    497          
    498            SampleApp_SendP2PBuffer(rsp, sizeof(rsp));
    499          }
    500          
    501          static void SampleApp_HandleTHCmd(void)
    502          {
    503            uint8 temp = 0xFF;
    504            uint8 hum  = 0xFF;
    505            uint8 rsp[7];
    506          
    507            /* When reading fails, first agree to return FF */
    508            if (!DHT11_Read(&temp, &hum))
    509            {
    510              temp = 0xEE;
    511              hum  = DHT11_LastErr;
    512            }
    513          
    514            rsp[0] = SH_START;
    515            rsp[1] = SH_TYPE_TH;
    516            rsp[2] = SAMPLEAPP_DEVICE_ADDR;
    517            rsp[3] = 0x02;   /* DATA length = 2 */
    518            rsp[4] = temp;
    519            rsp[5] = hum;
    520            rsp[6] = SH_END;
    521          
    522            SampleApp_SendP2PBuffer(rsp, sizeof(rsp));
    523          }
    524          

